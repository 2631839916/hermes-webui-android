<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_item_card"
    android:layout_margin="4dp"
    android:padding="12dp"
    android:gravity="center_vertical">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/text_task_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#1A1610"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_task_schedule"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#5C5344"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/text_task_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="#B8860B"
        android:background="@drawable/bg_status_badge"
        android:paddingHorizontal="8dp"
        android:paddingVertical="2dp" />

</LinearLayout>
